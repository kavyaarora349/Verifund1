{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci && cd backend && npm ci",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": ["dist/**", "backend/node_modules/.prisma/**", "backend/node_modules/@prisma/client/**"]
    }
  }
}

# Frontend (Vite) — required for two-site deploy (Vercel UI + API elsewhere), e.g.
#   https://your-api.onrender.com/api/v1
# Local dev: leave unset to use http://localhost:4000/api/v1
VITE_API_BASE_URL=

# GEMINI_API_KEY: Used by vite.config define (optional for AI features).
GEMINI_API_KEY=

# APP_URL: Hosted URL when deploying (callbacks, links).
APP_URL=

NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

DATABASE_URL=postgresql://postgres.project-ref:password@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require&pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres?sslmode=require
REDIS_URL=redis://localhost:6379

JWT_SECRET=your_super_secret_key_min16chars
JWT_REFRESH_SECRET=your_refresh_secret_min16chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Socket.IO CORS (comma-separated origins, or *)
SOCKET_CORS_ORIGINS=*

# Run BullMQ fraud worker in this process (set false to process fraud inline — dev only)
RUN_QUEUE_WORKER=true

# Amounts in API are rupees (integers); DB stores paise. Ledger routes high-value txs to Algorand when configured.
# Threshold in paise (default ≈ ₹1 Cr).
LEDGER_ALGORAND_THRESHOLD_PAISE=1000000000

ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_ADMIN_MNEMONIC=
ALGORAND_DEPT_HEAD_MNEMONIC=

FLAG_AMOUNT_MULTIPLIER=3.4
FLAG_VELOCITY_COUNT=2
FLAG_VELOCITY_WINDOW_HOURS=6
FLAG_WORKING_HOURS_START=9
FLAG_WORKING_HOURS_END=18
